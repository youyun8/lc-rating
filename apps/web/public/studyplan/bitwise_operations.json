      "title": "7. 線性基",
      "src": null,
      "summary": "**線性基 (Linear Basis) 模板**：\n用於解決異或相關的子集問題，如子集最大異或和。\n\n```cpp\n// 線性基：維護一組線性無關的位元向量，用於異或運算\n// 性質：線性基可以表示原集合所有子集異或的結果\nstruct LinearBasis {\n    long long d[64];  // d[i] 表示最高位為第 i 位的基向量\n    \n    // 初始化：所有基向量為 0\n    LinearBasis() {\n        memset(d, 0, sizeof(d));\n    }\n\n    // 插入一個數到線性基中\n    void insert(long long x) {\n        for (int i = 62; i >= 0; i--) {\n            if (!(x >> i)) {\n                continue;  // x 的第 i 位為 0，跳過\n            }\n            // x 的第 i 位為 1\n            if (!d[i]) {\n                d[i] = x;  // 第 i 位尚未有基底，直接設置\n                return;\n            }\n            x ^= d[i];  // 消去 x 的第 i 位，繼續嘗試更低位\n        }\n        // 若循環結束 x 變為 0，說明 x 可由現有基底線性表示\n    }\n\n    // 查詢最大異或和\n    long long queryMax() {\n        long long res = 0;\n        for (int i = 62; i >= 0; i--) {\n            // 貪心策略：若異或後結果更大則異或\n            res = max(res, res ^ d[i]);\n        }\n        return res;\n    }\n};\n```",
