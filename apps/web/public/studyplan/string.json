          "summary": "AC 自動機 = 字典樹 + KMP。用於多模式串匹配。可替代字串雜湊，適用於 1032、1408 等題。\n\n**C++ 模板**：\n\n```cpp\n// AC 自動機 = 字典樹 + KMP fail 指標\nstruct AhoCorasick {\n    vector<array<int, 26>> ch;   // 字典樹的邊\n    vector<int> fail;             // fail 指標（類似 KMP 的 next 陣列）\n    vector<int> cnt;              // 每個節點結尾的模式串數量\n    \n    // 建立新節點\n    int newNode() {\n        ch.push_back({});\n        fail.push_back(0);\n        cnt.push_back(0);\n        ch.back().fill(0);\n        return ch.size() - 1;\n    }\n    \n    // 建構子：初始化根節點\n    AhoCorasick() {\n        newNode();\n    }\n    \n    // 插入模式串到字典樹\n    void insert(const string& s) {\n        int cur = 0;\n        for (char c : s) {\n            int u = c - 'a';\n            // 如果該邊不存在，建立新節點\n            if (!ch[cur][u]) {\n                ch[cur][u] = newNode();\n            }\n            cur = ch[cur][u];\n        }\n        cnt[cur]++;  // 標記模式串結尾\n    }\n    \n    // 建立 fail 指標（類似 KMP 的預處理）\n    void build() {\n        queue<int> q;\n        // 第一層節點的 fail 指標都指向根節點\n        for (int i = 0; i < 26; i++) {\n            if (ch[0][i]) {\n                q.push(ch[0][i]);\n            }\n        }\n        // BFS 建立 fail 指標\n        while (!q.empty()) {\n            int u = q.front();\n            q.pop();\n            for (int i = 0; i < 26; i++) {\n                if (ch[u][i]) {\n                    // 節點存在：設定 fail 指標並加入佇列\n                    fail[ch[u][i]] = ch[fail[u]][i];\n                    q.push(ch[u][i]);\n                } else {\n                    // 節點不存在：直接指向 fail 位置的對應邊（路徑壓縮）\n                    ch[u][i] = ch[fail[u]][i];\n                }\n            }\n        }\n    }\n};\n```"
